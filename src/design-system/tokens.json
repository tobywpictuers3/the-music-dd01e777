{
  "brand": "Toby Music",
  "version": "2.0",
  "description": "Design tokens — Fire × Gold × Wine palette",
  "color": {
    "fire": {
      "bright": { "value": "#F3921E", "hsl": "hsl(32 92% 54%)", "usage": "CTA primary, highlights" },
      "core":   { "value": "#CF4112", "hsl": "hsl(20 88% 44%)", "usage": "gradient main" },
      "deep":   { "value": "#8E1B08", "hsl": "hsl(7 82% 30%)",  "usage": "depth, shadow, borders" }
    },
    "gold": {
      "light": { "value": "#ECC84E", "hsl": "hsl(46 80% 62%)", "usage": "glow, highlight, spark" },
      "main":  { "value": "#D9A22A", "hsl": "hsl(41 70% 51%)", "usage": "premium content, stars" },
      "dark":  { "value": "#AD7C1F", "hsl": "hsl(39 70% 40%)", "usage": "text on light background" }
    },
    "wine": {
      "deep":  { "value": "#63101E", "hsl": "hsl(350 59% 23%)", "usage": "dark backgrounds, deep chord" },
      "main":  { "value": "#9E2E3F", "hsl": "hsl(351 55% 40%)", "usage": "contact button" },
      "light": { "value": "#A8485A", "hsl": "hsl(349 40% 47%)", "usage": "hover, secondary accents" }
    },
    "neutral": {
      "950": { "value": "#150E09", "usage": "dark mode background" },
      "900": { "value": "#1E1510", "usage": "cards, panels" },
      "800": { "value": "#272018", "usage": "modals, dropdowns" },
      "700": { "value": "#3A2D24", "usage": "borders" },
      "500": { "value": "#8A7A72", "usage": "placeholder, inactive" },
      "200": { "value": "#CEBFB0", "usage": "borders light mode" },
      "100": { "value": "#EDE4D9", "usage": "cards light mode" },
      "50":  { "value": "#F8F4EE", "usage": "background light mode" }
    }
  },
  "typography": {
    "heading": {
      "family": "Frank Ruhl Libre",
      "fallback": "Playfair Display, Georgia, serif",
      "weights": [300, 400, 500, 700, 900],
      "usage": "H1–H4, Hebrew headings"
    },
    "display": {
      "family": "Cormorant Garamond",
      "fallback": "Frank Ruhl Libre, Georgia, serif",
      "weights": [300, 400, 600],
      "styles": ["italic"],
      "usage": "pull-quotes, Latin elegance"
    },
    "body": {
      "family": "Assistant",
      "fallback": "system-ui, -apple-system, sans-serif",
      "weights": [300, 400, 500, 600, 700],
      "usage": "body text, UI, nav, forms, buttons"
    }
  },
  "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Frank+Ruhl+Libre:wght@300;400;500;700;900&family=Assistant:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,400&display=swap",
  "spacing": {
    "cardPadding": "1.5rem",
    "radiusCard": "1rem",
    "radiusPill": "9999px"
  },
  "animation": {
    "fast":   { "duration": "0.18s", "easing": "ease-out",                          "usage": "hover, click, micro" },
    "normal": { "duration": "0.32s", "easing": "cubic-bezier(0.16, 1, 0.30, 1)",    "usage": "UI transitions" },
    "slow":   { "duration": "0.55s", "easing": "cubic-bezier(0.22, 1, 0.36, 1)",    "usage": "element entrance" },
    "hero":   { "duration": "1.4s",  "easing": "cubic-bezier(0.22, 1, 0.36, 1)",    "usage": "logo animation" },
    "breathe":{ "duration": "5s",    "easing": "ease-in-out", "iteration": "infinite", "usage": "fire glow pulse" }
  },
  "direction": "rtl",
  "defaultTheme": "dark"
}
